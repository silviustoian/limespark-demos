{
  "$schema": "Design tokens for LimeSpark templates. Every value here is injected as a CSS custom property at runtime by script.js. Change a value = change the whole site. Nothing visual is hardcoded in CSS or HTML.",

  "meta": {
    "template": "LimeSpark — Local Business Template v1",
    "variant": "detailing",
    "note": "Naming convention: a value at colors.brand becomes the CSS variable --color-brand. spacing.lg becomes --spacing-lg. And so on for every group."
  },

  "color": {
    "bg": "#FBFBF9",
    "bg-alt": "#F3F3F0",
    "surface": "#FFFFFF",
    "surface-2": "#F7F7F5",
    "ink": "#0B0B0C",
    "ink-soft": "#3A3A3E",
    "muted": "#6B6B72",
    "line": "rgba(11, 11, 12, 0.09)",
    "line-strong": "rgba(11, 11, 12, 0.16)",
    "brand": "#0B0B0C",
    "brand-contrast": "#FFFFFF",
    "accent": "#1E8BFF",
    "accent-ink": "#FFFFFF",
    "highlight": "#1E8BFF",
    "success": "#1F9D55",
    "star": "#1E8BFF",
    "dark-bg": "#0A0A0B",
    "dark-surface": "#12141A",
    "dark-ink": "#F5F5F3",
    "dark-muted": "#9A9AA2",
    "dark-line": "rgba(255, 255, 255, 0.12)",
    "overlay": "rgba(11, 11, 12, 0.55)"
  },

  "font": {
    "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
    "display": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "mono": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
    "weight-normal": "400",
    "weight-medium": "500",
    "weight-semibold": "600",
    "weight-bold": "700",
    "tracking-tight": "-0.02em",
    "tracking-tighter": "-0.035em",
    "tracking-wide": "0.14em",
    "leading-tight": "1.05",
    "leading-snug": "1.2",
    "leading-normal": "1.6"
  },

  "fluid": {
    "step--1": "clamp(0.82rem, 0.79rem + 0.15vw, 0.9rem)",
    "step-0": "clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem)",
    "step-1": "clamp(1.1rem, 1rem + 0.4vw, 1.35rem)",
    "step-2": "clamp(1.35rem, 1.15rem + 0.9vw, 1.9rem)",
    "step-3": "clamp(1.8rem, 1.4rem + 1.8vw, 2.9rem)",
    "step-4": "clamp(2.4rem, 1.7rem + 3vw, 4.2rem)",
    "step-5": "clamp(3rem, 2rem + 4.6vw, 6rem)"
  },

  "spacing": {
    "xs": "0.5rem",
    "sm": "0.75rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2.5rem",
    "2xl": "4rem",
    "3xl": "6rem",
    "section": "clamp(4.5rem, 3rem + 7vw, 9rem)",
    "gutter": "clamp(1.25rem, 0.5rem + 3vw, 3rem)",
    "container": "1240px",
    "container-narrow": "820px"
  },

  "radius": {
    "sm": "10px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "pill": "999px"
  },

  "shadow": {
    "xs": "0 1px 2px rgba(11, 11, 12, 0.05)",
    "sm": "0 4px 14px rgba(11, 11, 12, 0.06)",
    "md": "0 14px 40px rgba(11, 11, 12, 0.09)",
    "lg": "0 30px 70px rgba(11, 11, 12, 0.14)",
    "ring": "0 0 0 1px rgba(11, 11, 12, 0.08)"
  },

  "motion": {
    "fast": "160ms",
    "base": "260ms",
    "slow": "520ms",
    "ease": "cubic-bezier(0.22, 1, 0.36, 1)",
    "ease-in-out": "cubic-bezier(0.65, 0, 0.35, 1)",
    "reveal-distance": "22px"
  },

  "layout": {
    "header-height": "68px",
    "border-width": "1px"
  }
}
